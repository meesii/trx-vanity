{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "TRX Vanity",
    "version": "0.1.2",
    "identifier": "com.vcloud.trx-vanity",
    "build": {
        "beforeDevCommand": "npm.cmd run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm.cmd run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "TRX Wallet Studio",
                "width": 1280,
                "height": 820,
                "minWidth": 1040,
                "minHeight": 720
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/logo.ico"
        ],
        "windows": {
            "nsis": {
                "installMode": "both",
                "displayLanguageSelector": false,
                "languages": [
                    "SimpChinese"
                ],
                "installerIcon": "icons/logo.ico"
            },
            "webviewInstallMode": {
                "type": "offlineInstaller"
            }
        }
    }
}